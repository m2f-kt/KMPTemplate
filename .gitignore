*.iml
.kotlin
.gradle
**/build/
xcuserdata

# JVM crash dumps (hs_err_pid<N>.log / replay_pid<N>.log) — local artifacts, never commit
hs_err_pid*.log
replay_pid*.log
!src/**/build/
local.properties
.idea
!.idea/runConfigurations/
.DS_Store
captures
.externalNativeBuild
.cxx
*.xcodeproj/*
!*.xcodeproj/project.pbxproj
!*.xcodeproj/xcshareddata/
!*.xcodeproj/project.xcworkspace/
!*.xcworkspace/contents.xcworkspacedata
**/xcshareddata/WorkspaceSettings.xcsettings
/kotlin-js-store/wasm/yarn.lock
__pycache__/
*.http
http-client.env.json
.env
.worktrees/

# detekt CLI jars cached by the detekt-on-edit autofix hook (fetched on first use)
.claude/hooks/.detekt/

# graphify: only ignore the machine-specific Python interpreter path
graphify-out/.graphify_python

# graphify: machine-generated AST cache (regenerated on rebuild)
graphify-out/cache/
