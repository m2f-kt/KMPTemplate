### Login and save tokens
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

> {%
    client.test("Login successful", function () {
        client.assert(response.status === 200, "Expected 200 OK");
        client.global.set("access_token", response.body.accessToken);
        client.global.set("refresh_token", response.body.refreshToken);
    });
%}

### Assistant agent
POST {{host}}/api/ai/assistant
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "message": "How many users are registered?"
}

> {%
    client.test("Assistant responded", function () {
        client.assert(response.status === 200, "Expected 200 OK");
        client.assert(response.body.agentType === "assistant", "Expected assistant agent type");
    });
%}

### Chat stream – new conversation
GET {{host}}/api/ai/chat/stream?token={{access_token}}&message=Hello! What can you help me with?

### Chat stream – continue conversation
GET {{host}}/api/ai/chat/stream?token={{access_token}}&message=Can you remind me what I just asked?&conversationId={{conversation_id}}
