# ─────────────────────────────────────────────
# HTTP Server
# ─────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
BASE_URL=http://localhost:8080
APP_URL=http://localhost:8081

# ─────────────────────────────────────────────
# Authentication (JWT)
# ─────────────────────────────────────────────
JWT_SECRET=ThisIsAReallyReallyReallyStrongSecretKeyForJWT123!@#$%^&*()
JWT_AUDIENCE=jwt-audience
JWT_ISSUER=IssuerName
JWT_REALM=Access to Your Application
JWT_ACCESS_EXPIRY=86400000
JWT_REFRESH_EXPIRY=2592000000

# ─────────────────────────────────────────────
# OAuth Providers (optional — leave empty to disable)
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_TEAM_ID=
APPLE_KEY_ID=
OAUTH_WASM_REDIRECT_URL=http://localhost:8080/auth/callback
OAUTH_MOBILE_SCHEME=template
OAUTH_DESKTOP_LOCALHOST_PORT=9876

# ─────────────────────────────────────────────
# AI (optional — set AI_ENABLED=true to activate)
# ─────────────────────────────────────────────
AI_ENABLED=false
GOOGLE_API_KEY=

# ─────────────────────────────────────────────
# S3 / MinIO (local dev defaults)
# ─────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9002
S3_BUCKET=uploads
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ─────────────────────────────────────────────
# Email / SMTP (MailHog local dev defaults)
# ─────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@template.local
