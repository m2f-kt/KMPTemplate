      { "symbol": "Ttr",   "id": "yRRLK", "name": "Terminal Table Row",            "kotlin": "TerminalTableRow(...) // also TerminalSelectableTableRow", "file": "components/data/TerminalTable.kt",      "use_for": "row inside Terminal Table" },
      { "symbol": "Tl",    "id": "xiRqf", "name": "Terminal List",                 "kotlin": "TerminalList(...)",                                        "file": "components/data/TerminalList.kt",       "use_for": "vertical list container" },
      { "symbol": "Tli-d", "id": "1HAho", "name": "Terminal List Item/Default",    "kotlin": "TerminalListItem(state = ListItemState.Default, ...)",     "file": "components/data/TerminalList.kt",       "use_for": "resting list row" },
      { "symbol": "Tli-h", "id": "nvEsK", "name": "Terminal List Item/Hover",      "kotlin": "TerminalListItem(state = ListItemState.Hover, ...)",       "file": "components/data/TerminalList.kt",       "use_for": "hovered list row preview" },
      { "symbol": "Tli-s", "id": "cZWar", "name": "Terminal List Item/Selected",   "kotlin": "TerminalListItem(state = ListItemState.Selected, ...)",    "file": "components/data/TerminalList.kt",       "use_for": "selected list row" },
      { "symbol": "Tli-x", "id": "vCa6P", "name": "Terminal List Item/Disabled",   "kotlin": "TerminalListItem(state = ListItemState.Disabled, ...)",    "file": "components/data/TerminalList.kt",       "use_for": "disabled list row" }
