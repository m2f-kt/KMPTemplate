      { "symbol": "Tta",   "id": "mMor5", "name": "Terminal Textarea",             "kotlin": "TerminalTextarea(...)",                                    "file": "components/input/TerminalTextarea.kt",  "use_for": "multi-line text input" },
      { "symbol": "Tch-d", "id": "ryDIe", "name": "Terminal Checkbox/Default",     "kotlin": "TerminalCheckbox(checked = false, onCheckedChange, ...)",  "file": "components/selection/TerminalCheckbox.kt", "use_for": "unchecked binary toggle (also: tri-state overload via ToggleableState)" },
      { "symbol": "Tch-c", "id": "ut9mj", "name": "Terminal Checkbox/Checked",     "kotlin": "TerminalCheckbox(checked = true, onCheckedChange, ...)",   "file": "components/selection/TerminalCheckbox.kt", "use_for": "checked binary toggle" },
      { "symbol": "Tsw-d", "id": "4Ibe8", "name": "Terminal Switch/Default",       "kotlin": "TerminalSwitch(checked = false, onCheckedChange, ...)",    "file": "components/selection/TerminalSwitch.kt",   "use_for": "unchecked setting toggle" },
      { "symbol": "Tsw-c", "id": "pWKbD", "name": "Terminal Switch/Checked",       "kotlin": "TerminalSwitch(checked = true, onCheckedChange, ...)",     "file": "components/selection/TerminalSwitch.kt",   "use_for": "checked setting toggle" },
      { "symbol": "Tr-d",  "id": "DlDhX", "name": "Terminal Radio/Default",        "kotlin": "TerminalRadio(selected = false, onClick, ...)",            "file": "components/selection/TerminalRadio.kt",    "use_for": "unselected option in exclusive group" },
      { "symbol": "Tr-c",  "id": "JwPq6", "name": "Terminal Radio/Checked",        "kotlin": "TerminalRadio(selected = true, onClick, ...)",             "file": "components/selection/TerminalRadio.kt",    "use_for": "selected option in exclusive group" }
