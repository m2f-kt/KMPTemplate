  "code_only_components": {
    "_purpose": "Composables that exist in code but have no Pencil ref. Use them only when they appear here. Each is awaiting either a Pencil ref or an explicit decision to remain code-only.",
    "primitives": [
      { "kotlin": "TerminalText(...)", "file": "components/TerminalText.kt", "use_for": "Text token primitive — every other component composes through it. Code-only by design." }
    ],
    "data_extras": [
      { "kotlin": "TerminalBarChart(...)",       "file": "components/data/TerminalBarChart.kt",        "use_for": "vertical/horizontal bar chart; uses chart.* tokens" },
      { "kotlin": "TerminalLineChart(...)",      "file": "components/data/TerminalLineChart.kt",       "use_for": "line chart with axes" },
      { "kotlin": "TerminalRadarChart(...)",     "file": "components/data/TerminalRadarChart.kt",      "use_for": "radar/spider chart" },
      { "kotlin": "TerminalDropdownMenu(...) + TerminalDropdownMenuItem(...)", "file": "components/data/TerminalDropdownMenu.kt", "use_for": "popup menu surface + rows" },
      { "kotlin": "TerminalReorderableList(...) + rememberReorderState", "file": "components/data/TerminalReorderableList.kt", "use_for": "drag-to-reorder generic list" },
      { "kotlin": "TerminalSwipeReveal(...) + TerminalDeleteAction(...)", "file": "components/data/TerminalSwipeReveal.kt", "use_for": "swipe-to-reveal with built-in delete affordance" },
      { "kotlin": "TerminalSelectableTable(...) + TerminalSelectableTableRow(...)", "file": "components/data/TerminalTable.kt", "use_for": "multi-select table variant" }
    ],
    "input_extras": [
      { "kotlin": "TerminalPasswordInput(...)", "file": "components/input/TerminalInput.kt", "use_for": "password field with eye-toggle (built on TerminalInput)" }
    ],
    "platform_utilities": [
      { "kotlin": "rememberImagePickerLauncher() // expect/actual", "file": "components/picker/ImagePicker.kt", "use_for": "multiplatform image picker — no Pencil UI ref" }
    ]
  },

