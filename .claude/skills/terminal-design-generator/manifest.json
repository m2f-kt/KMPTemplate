      { "symbol": "Tc-a",  "id": "zCm6A", "name": "Terminal Card/Accent",          "kotlin": "TerminalCard(variant = CardVariant.Accent, ...)",          "file": "components/card/TerminalCard.kt",       "use_for": "card with strong emphasis" },
      { "symbol": "Tc-i",  "id": "DeFHT", "name": "Terminal Card/Info",            "kotlin": "TerminalCard(variant = CardVariant.Info, ...)",            "file": "components/card/TerminalCard.kt",       "use_for": "informational card with info semantic" },
      { "symbol": "Tc-h",  "id": "U8SOz", "name": "Terminal Card/Highlighted",     "kotlin": "TerminalCard(variant = CardVariant.Highlighted, ...)",     "file": "components/card/TerminalCard.kt",       "use_for": "featured / singled-out card" },
