      { "symbol": "Tba-a", "id": "Zek57", "name": "Terminal Badge/Accent",         "kotlin": "TerminalBadge(variant = BadgeVariant.Accent, ...)",        "file": "components/feedback/TerminalBadge.kt",  "use_for": "emphasized status" },
      { "symbol": "Tba-s", "id": "alR2r", "name": "Terminal Badge/Success",        "kotlin": "TerminalBadge(variant = BadgeVariant.Success, ...)",       "file": "components/feedback/TerminalBadge.kt",  "use_for": "success status" },
      { "symbol": "Tba-w", "id": "AVukf", "name": "Terminal Badge/Warning",        "kotlin": "TerminalBadge(variant = BadgeVariant.Warning, ...)",       "file": "components/feedback/TerminalBadge.kt",  "use_for": "warning status" },
      { "symbol": "Tba-e", "id": "F5EHO", "name": "Terminal Badge/Error",          "kotlin": "TerminalBadge(variant = BadgeVariant.Error, ...)",         "file": "components/feedback/TerminalBadge.kt",  "use_for": "error status" },
