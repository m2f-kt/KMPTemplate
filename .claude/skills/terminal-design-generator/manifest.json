      "sheet_bg":       "#0A0A0A",
      "drawing":        "#0D0D0D",
      "header_strip":   "#171717",
      "border_light":   "#2A2A2E",
      "wall_heavy":     "#A3A3A3",
      "wall_light":     "#6B6B6B",
      "dim_text":       "#525252",
      "callout_accent": "#6BAF8A"
    }
  },

  "rules": {
    "required": [
      "Every component-shaped node MUST be type:'ref' to one of the 41 IDs in components.*",
      "Every fill / stroke.fill / effect.color in Pencil MUST be a $-- variable from tokens",
      "Every Kotlin Color usage in app:designsystem MUST come from TerminalTheme.colors.*",
      "Every Kotlin font size MUST come from TerminalTheme.typography.* (no inline .sp)",
      "Every Kotlin spacing/padding/gap MUST come from TerminalTheme.spacing.* or .gap.* (no inline .dp other than 0/1/2 hairlines and Canvas stroke widths)",
      "Every Kotlin corner radius MUST come from TerminalTheme.radius.*",
      "Customize component instances via U(instance + '/childId', {...}) or descendants overrides — never recreate the shape"
    ],
    "forbidden": [
      "Hex colors (#XXXXXX) on any property — except inside atlas_palette zones owning the color",
      "Raw font family strings (e.g. 'JetBrains Mono')",
      "Off-scale font sizes — must use one of typography.scale entries",
      "Off-scale spacing values — must use spacing.scale or gap.scale",
      "Recreating a component by composing primitives when a ref exists",
      "Inventing a component that does not exist in components.* or code_only_components.*"
    ],
    "escape_hatches": [
      {
        "name": "positional-canvas",
        "applies_to": "x / y / width / height of children inside a layout:'none' parent",
        "rule": "may be any integer; tag parent name with '// reason: positional canvas'"
      },
      {
        "name": "atlas-secondary-palette",
        "applies_to": "v3 Periodic / v4 Transit / v5 Blueprint atlases",
        "rule": "use atlas_palette colors only inside the owning atlas frame; never leak into product screens"
      },
      {
        "name": "canvas-stroke-width",
        "applies_to": "Compose Canvas { drawLine/drawRect } stroke widths",
        "rule": "1.dp..3.dp inline is acceptable; route through TerminalTheme.borders.* when the value is exactly 1/2/3"
      }
    ]
  }
}
