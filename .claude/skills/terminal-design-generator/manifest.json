      { "symbol": "Talr-s","id": "5E3LA", "name": "Terminal Alert/Success",        "kotlin": "TerminalAlert(variant = AlertVariant.Success, ...)",       "file": "components/feedback/TerminalAlert.kt",  "use_for": "confirmation of completion" },
      { "symbol": "Talr-w","id": "H79gt", "name": "Terminal Alert/Warning",        "kotlin": "TerminalAlert(variant = AlertVariant.Warning, ...)",       "file": "components/feedback/TerminalAlert.kt",  "use_for": "recoverable issue" },
      { "symbol": "Talr-e","id": "t4WAf", "name": "Terminal Alert/Error",          "kotlin": "TerminalAlert(variant = AlertVariant.Error, ...)",         "file": "components/feedback/TerminalAlert.kt",  "use_for": "blocking issue" },
      { "symbol": "Tpr-d", "id": "OvoQ4", "name": "Terminal Progress",             "kotlin": "TerminalProgress(progress = <Float>, ...)",                "file": "components/feedback/TerminalProgress.kt","use_for": "determinate progress" },
      { "symbol": "Tpr-i", "id": "YP7h8", "name": "Terminal Progress/Indeterminate","kotlin":"TerminalProgress(progress = null, ...)",                   "file": "components/feedback/TerminalProgress.kt","use_for": "indeterminate progress (null sentinel on `progress: Float?`)" },
      { "symbol": "Ttp",   "id": "fHrNh", "name": "Terminal Tooltip",              "kotlin": "TerminalTooltip(...)",                                     "file": "components/feedback/TerminalTooltip.kt","use_for": "on-hover contextual help" }
    ],
    "display": [
