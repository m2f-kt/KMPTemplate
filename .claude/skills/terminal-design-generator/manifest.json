    "utility": [
      { "symbol": "Tav",   "id": "6cukz", "name": "Terminal Avatar",               "kotlin": "TerminalAvatar(...)",                                      "file": "components/display/TerminalAvatar.kt",  "use_for": "user identity glyph" },
      { "symbol": "Tk",    "id": "8cfy6", "name": "Terminal Kbd",                  "kotlin": "TerminalKbd(text = \"⌘K\", ...)",                    "file": "components/display/TerminalKbd.kt",     "use_for": "keyboard chord glyph" }
    ]
