      { "symbol": "Tb-g",  "id": "zNQZK", "name": "Terminal Button/Ghost",         "kotlin": "TerminalButton(variant = ButtonVariant.Ghost, ...)",       "file": "components/button/TerminalButton.kt",   "use_for": "tertiary / inline link-like action" },
      { "symbol": "Tb-x",  "id": "FQxTP", "name": "Terminal Button/Destructive",   "kotlin": "TerminalButton(variant = ButtonVariant.Destructive, ...)", "file": "components/button/TerminalButton.kt",   "use_for": "irreversible / data-loss action" },
